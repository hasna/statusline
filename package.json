{
  "name": "@hasna/statusline",
  "version": "0.0.1",
  "description": "Tiny composable statusline CLI for AI coding agents — pre-built toggleable segments for Claude Code, with a provider model for others",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "statusline": "./dist/cli.js",
    "statusline-mcp": "./dist/mcp/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/cli.ts src/mcp/index.ts --outdir dist --target bun && tsc -p tsconfig.build.json && chmod +x dist/cli.js dist/mcp/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/statusline.git"
  },
  "homepage": "https://github.com/hasna/statusline#readme",
  "bugs": {
    "url": "https://github.com/hasna/statusline/issues"
  },
  "keywords": [
    "statusline",
    "status-bar",
    "claude-code",
    "cli",
    "bun"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  }
}
